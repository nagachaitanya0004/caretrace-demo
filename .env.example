# Database Binding
MONGO_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
DB_NAME="caretrace_ai"

# Access Credentials
SECRET_KEY="GENERATED_BY_RENDER_OR_YOUR_OWN_SECURE_STRING"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="10000"

# Security Frameworks
# Separate multiple origins with commas: https://myfrontend.vercel.app,http://localhost:5173
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
