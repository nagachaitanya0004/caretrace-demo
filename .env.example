# ═══════════════════════════════════════════════════════════════════════════
# CareTrace AI - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# 
# SECURITY WARNING: Never commit the actual .env file to version control!
# This file contains sensitive credentials that must be kept secret.
#
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Update all placeholder values with your actual credentials
# 3. Generate a strong SECRET_KEY (see instructions below)
# 4. Verify .env is listed in .gitignore
#
# ═══════════════════════════════════════════════════════════════════════════

# ─── Database Configuration ──────────────────────────────────────────────────
# MongoDB connection string (PRIMARY DATABASE - Currently Active)
# For MongoDB Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<app-name>
# For local MongoDB: mongodb://localhost:27017
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=caretrace-ai

# Database name
DB_NAME=caretrace_ai

# PostgreSQL connection string (OPTIONAL - For future migration)
# Format: postgresql+asyncpg://username:password@host:port/database
# Example local: postgresql+asyncpg://postgres:postgres@localhost:5432/caretrace_ai
# Example cloud: postgresql+asyncpg://user:pass@db.example.com:5432/caretrace_ai
# NOTE: This is currently NOT used by the application. MongoDB is the active database.
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/caretrace_ai

# ─── Security Configuration ──────────────────────────────────────────────────
# JWT Secret Key - CRITICAL: Must be a strong random string
# 
# Generate a secure key with one of these commands:
#   Python:  python -c "import secrets; print(secrets.token_hex(32))"
#   OpenSSL: openssl rand -hex 32
#   Node:    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# NEVER use default values or weak keys in production!
# Minimum 32 characters (64 hex characters recommended)
SECRET_KEY=your-secret-key-min-32-characters-long-replace-this-with-generated-value

# JWT Algorithm (HS256 is recommended)
ALGORITHM=HS256

# Token expiration time in minutes
# 10080 = 7 days, 1440 = 1 day, 60 = 1 hour
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── CORS Configuration ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# 
# Development (local):
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
#
# Production (update with your actual domains):
# CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com
#
# SECURITY: Never use wildcards (*) in production!

# ─── Application Configuration (Optional) ────────────────────────────────────
# APP_NAME=CareTrace AI Backend
# APP_VERSION=1.0.0

# ═══════════════════════════════════════════════════════════════════════════
# Production Deployment Checklist:
# ═══════════════════════════════════════════════════════════════════════════
# 
# [ ] Generated strong random SECRET_KEY (64+ hex characters)
# [ ] Updated MONGO_URI with production database credentials
# [ ] Set CORS_ORIGINS to actual frontend domain(s)
# [ ] Verified .env file is NOT committed to git
# [ ] Different credentials for dev/staging/production
# [ ] MongoDB IP whitelist configured
# [ ] Database user has appropriate permissions (not admin)
# [ ] Enabled MongoDB encryption at rest
# [ ] Set up database backups
# [ ] Configured monitoring and logging
# 
# ═══════════════════════════════════════════════════════════════════════════
